&НаКлиенте
Процедура ВидНоменклатурыПриИзменении(Элемент)
	Если Не ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		Возврат;
	КонецЕсли;
	СобратьИПостроитьТаблицуНаСервере();
КонецПроцедуры

&НаСервере
Процедура СобратьИПостроитьТаблицуНаСервере()
	
	Запрос = Новый Запрос;
	ИспользоватьОтбор = Ложь;
	СписокНоменклатуры = Новый Массив;
	ТаблицаОтбора = РеквизитФормыВЗначение("ПараметрыОтбора");
	
	Если ТаблицаОтбора <> Неопределено Тогда
		Если ТаблицаОтбора.Количество() > 0 Тогда
			ИспользоватьОтбор = Истина;
			СписокНоменклатуры = ПолучитьСписокНоменклатурыПоОтбору();
			
			Если СписокНоменклатуры.Количество() = 0 Тогда
				ЭтаФорма.ТаблицаПрайса.Очистить();
				ЗаполнитьДеревоМатериаловИзКонтекстаТИНаСервере(СоздатьПустуюТаблицуТИДляМатериалов());
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СпрНоменклатура.Ссылка КАК Номенклатура,
	|	ТИ.ТехнологическаяИнструкция КАК ТИ,
	|	кт_ТрудоемкостиТехнологическихИнструкцийСрезПоследних.ВидРабот КАК ВидРабот,
	|	ЕСТЬNULL(кт_ТрудоемкостиТехнологическихИнструкцийСрезПоследних.ВидРабот.СтоимостьМинуты, 0) КАК ЦенаМинуты,
	|	ЕСТЬNULL(кт_ТрудоемкостиТехнологическихИнструкцийСрезПоследних.Трудоемкость, 0) КАК ВременныеЗатратыМинуты
	|ПОМЕСТИТЬ ВТ_ПлоскиеДанные
	|ИЗ
	|	Справочник.Номенклатура КАК СпрНоменклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.кт_АктуальнаяТИНоменклатуры КАК ТИ
	|		ПО СпрНоменклатура.Ссылка = ТИ.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.кт_ТрудоемкостиТехнологическихИнструкций.СрезПоследних(, ) КАК кт_ТрудоемкостиТехнологическихИнструкцийСрезПоследних
	|		ПО (ТИ.ТехнологическаяИнструкция = кт_ТрудоемкостиТехнологическихИнструкцийСрезПоследних.ТехнологическаяИнструкция)
	|ГДЕ
	|	СпрНоменклатура.ВидНоменклатуры = &ВидНоменклатуры
	|	И СпрНоменклатура.ЭтоГруппа = ЛОЖЬ
	|	И (&ИспользоватьОтбор = ЛОЖЬ
	|		ИЛИ СпрНоменклатура.Ссылка В (&СписокНоменклатуры))	
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_ПлоскиеДанные.ВидРабот КАК ВидРабот2,
	|	ВТ_ПлоскиеДанные.ЦенаМинуты КАК ЦенаМинуты2,
	|	кт_ЦеныВидовРаботСрезПоследних.Цена КАК ЦенаМинуты,
	|	кт_ЦеныВидовРаботСрезПоследних.ВидРабот КАК ВидРабот
	|ИЗ
	|	ВТ_ПлоскиеДанные КАК ВТ_ПлоскиеДанные,
	|	РегистрСведений.кт_ЦеныВидовРабот.СрезПоследних КАК кт_ЦеныВидовРаботСрезПоследних
	|ГДЕ
	|	ВТ_ПлоскиеДанные.ВидРабот ЕСТЬ НЕ NULL 
	|	И кт_ЦеныВидовРаботСрезПоследних.ВидРабот ЕСТЬ НЕ NULL 
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТ_ПлоскиеДанные.Номенклатура КАК Номенклатура,
	|	ВТ_ПлоскиеДанные.ТИ КАК ТехнологическаяИнструкция
	|ИЗ
	|	ВТ_ПлоскиеДанные КАК ВТ_ПлоскиеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПлоскиеДанные.Номенклатура КАК Номенклатура,
	|	ВТ_ПлоскиеДанные.ВидРабот КАК ВидРабот,
	|	ВТ_ПлоскиеДанные.ЦенаМинуты КАК ЦенаМинуты,
	|	СУММА(ВТ_ПлоскиеДанные.ВременныеЗатратыМинуты) КАК Минуты
	|ИЗ
	|	ВТ_ПлоскиеДанные КАК ВТ_ПлоскиеДанные
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ПлоскиеДанные.Номенклатура,
	|	ВТ_ПлоскиеДанные.ВидРабот,
	|	ВТ_ПлоскиеДанные.ЦенаМинуты
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура
	|ИТОГИ ПО
	|	Номенклатура";
	
	Запрос.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
	Запрос.УстановитьПараметр("ИспользоватьОтбор", ИспользоватьОтбор);
	Запрос.УстановитьПараметр("СписокНоменклатуры", СписокНоменклатуры);
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	ТаблицаВидовРабот = МассивРезультатов[1].Выгрузить();
	ТаблицаТИДляМатериалов = МассивРезультатов[2].Выгрузить();
	РезультатДерево = МассивРезультатов[3].Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	ЗаполнитьДеревоМатериаловИзКонтекстаТИНаСервере(ТаблицаТИДляМатериалов);
	
	МассивДобавляемыхРеквизитов = Новый Массив;
	МассивУдаляемыхРеквизитов = Новый Массив;
	
	Попытка
		Для Каждого ТекКолонка Из ЭтаФорма.ТаблицаПрайса.Выгрузить().Колонки Цикл
			МассивУдаляемыхРеквизитов.Добавить("ТаблицаПрайса." + ТекКолонка.Имя);
		КонецЦикла;
	Исключение
	КонецПопытки;
	
	МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Выбран", Новый ОписаниеТипов("Булево"), "ТаблицаПрайса", " "));
	МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Номенклатура", Новый ОписаниеТипов("СправочникСсылка.Номенклатура"), "ТаблицаПрайса", "Номенклатура"));
	
	СоответствиеКолонок = Новый Соответствие;
	Счетчик = 1;
	Для Каждого СтрокаРаботы Из ТаблицаВидовРабот Цикл
		УИД = Строка(СтрокаРаботы.ВидРабот.УникальныйИдентификатор());
		ИмяЧасы = "Часы_" + Счетчик;
		ИмяСумма = "Сумма_" + Счетчик;
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяЧасы, Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)), "ТаблицаПрайса"));
		МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы(ИмяСумма, Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)), "ТаблицаПрайса"));
		СоответствиеКолонок.Вставить(УИД, Новый Структура("Часы, Сумма, ЦенаМин, Синоним", ИмяЧасы, ИмяСумма, СтрокаРаботы.ЦенаМинуты, Строка(СтрокаРаботы.ВидРабот)));
		Счетчик = Счетчик + 1;
	КонецЦикла;
	
	МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("Материалы", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)), "ТаблицаПрайса", "Материалы"));
	МассивДобавляемыхРеквизитов.Добавить(Новый РеквизитФормы("ЦенаНовая", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)), "ТаблицаПрайса", "Цена новая"));
	
	ЭтаФорма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов, МассивУдаляемыхРеквизитов);
	
	ЭлементТаблица = Элементы.ТаблицаПрайса;
	МассивДляУдаления = Новый Массив;
	Для Каждого ПодчиненныйЭлемент Из ЭлементТаблица.ПодчиненныеЭлементы Цикл
		МассивДляУдаления.Добавить(ПодчиненныйЭлемент);
	КонецЦикла;
	
	Для Каждого Эл Из МассивДляУдаления Цикл
		Элементы.Удалить(Эл);
	КонецЦикла;
	
	ЗеленыйЦвет = Новый Цвет(0, 150, 0);
	
	НовЭл = Элементы.Добавить("Эл_Выбран", Тип("ПолеФормы"), ЭлементТаблица);
	НовЭл.Вид = ВидПоляФормы.ПолеФлажка;
	НовЭл.ПутьКДанным = "ТаблицаПрайса.Выбран";
	НовЭл.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	
	НовЭл = Элементы.Добавить("Эл_Номенклатура", Тип("ПолеФормы"), ЭлементТаблица);
	НовЭл.Вид = ВидПоляФормы.ПолеВвода;
	НовЭл.ПутьКДанным = "ТаблицаПрайса.Номенклатура";
	НовЭл.ТолькоПросмотр = Истина;
	НовЭл.Заголовок = "Номенклатура";
	
	ГруппаВерхняя = Элементы.Добавить("ГруппаВерхняя", Тип("ГруппаФормы"), ЭлементТаблица);
	ГруппаВерхняя.Вид = ВидГруппыФормы.ГруппаКолонок;
	ГруппаВерхняя.Группировка = ГруппировкаКолонок.Горизонтальная;
	ГруппаВерхняя.Заголовок = "Вид работ/Трудоемкость (ч.)/стоимость (руб/мин)";
	ГруппаВерхняя.ОтображатьВШапке = Истина;
	
	Для Каждого Кв Из СоответствиеКолонок Цикл
		Данные = Кв.Значение;
		ЦенаДляЗаголовка = ?(Данные.ЦенаМин = NULL, 0, Данные.ЦенаМин);
		
		ГрВид = Элементы.Добавить("Гр_" + Данные.Часы, Тип("ГруппаФормы"), ГруппаВерхняя);
		ГрВид.Вид = ВидГруппыФормы.ГруппаКолонок;
		ГрВид.Группировка = ГруппировкаКолонок.Вертикальная;
		ГрВид.ОтображатьВШапке = Ложь;
		
		ЭлЧасы = Элементы.Добавить("Эл_" + Данные.Часы, Тип("ПолеФормы"), ГрВид);
		ЭлЧасы.Вид = ВидПоляФормы.ПолеВвода;
		ЭлЧасы.ПутьКДанным = "ТаблицаПрайса." + Данные.Часы;
		ЭлЧасы.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Верх;
		ЭлЧасы.Заголовок = Данные.Синоним;
		ЭлЧасы.ТолькоПросмотр = Истина;
		ЭлЧасы.Шрифт = Новый Шрифт(ЭлЧасы.Шрифт, , , Истина);
		
		ЭлСумма = Элементы.Добавить("Эл_" + Данные.Сумма, Тип("ПолеФормы"), ГрВид);
		ЭлСумма.Вид = ВидПоляФормы.ПолеВвода;
		ЭлСумма.ПутьКДанным = "ТаблицаПрайса." + Данные.Сумма;
		ЭлСумма.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Верх;
		ЭлСумма.Заголовок = Формат(ЦенаДляЗаголовка, "ЧГ=0; ЧДЦ=0") + " руб/мин";
		ЭлСумма.ЦветТекста = ЗеленыйЦвет;
		ЭлСумма.ТолькоПросмотр = Истина;
		ЭлСумма.Шрифт = Новый Шрифт(ЭлСумма.Шрифт, , , Истина);
	КонецЦикла;
	
	ЭлМат = Элементы.Добавить("Эл_Материалы", Тип("ПолеФормы"), ЭлементТаблица);
	ЭлМат.Вид = ВидПоляФормы.ПолеВвода;
	ЭлМат.ПутьКДанным = "ТаблицаПрайса.Материалы";
	ЭлМат.Заголовок = "Материалы";
	ЭлМат.ТолькоПросмотр = Истина;
	
	ЭлЦена = Элементы.Добавить("Эл_ЦенаНовая", Тип("ПолеФормы"), ЭлементТаблица);
	ЭлЦена.Вид = ВидПоляФормы.ПолеВвода;
	ЭлЦена.ПутьКДанным = "ТаблицаПрайса.ЦенаНовая";
	ЭлЦена.Заголовок = "Цена новая";
	ЭлЦена.ТолькоПросмотр = Истина;
	ЭлЦена.Шрифт = Новый Шрифт(ЭлЦена.Шрифт, , , Истина);
	ЭтаФорма.ТаблицаПрайса.Очистить();
	
	Для Каждого УзелНоменклатуры Из РезультатДерево.Строки Цикл
		НоваяСтрока = ЭтаФорма.ТаблицаПрайса.Добавить();
		НоваяСтрока.Номенклатура = УзелНоменклатуры.Номенклатура;
		СуммаИтого = 0;
		Для Каждого УзелРаботы Из УзелНоменклатуры.Строки Цикл
			Если УзелРаботы.ВидРабот = NULL Тогда Продолжить; КонецЕсли;
			УИД = Строка(УзелРаботы.ВидРабот.УникальныйИдентификатор());
			Данные = СоответствиеКолонок[УИД];
			Если Данные <> Неопределено Тогда
				
				
				Минуты = УзелРаботы.Минуты; 
				Цена = ?(Данные.ЦенаМин = NULL, 0, Данные.ЦенаМин);
				
				
				НоваяСтрока[Данные.Часы] = Окр(Минуты / 60, 2);
				
				
				СуммаОперации = Минуты * Цена;
				
				НоваяСтрока[Данные.Сумма] = СуммаОперации;
				СуммаИтого = СуммаИтого + СуммаОперации;
			КонецЕсли;
		КонецЦикла;
		НоваяСтрока.ЦенаНовая = СуммаИтого;
	КонецЦикла;
КонецПроцедуры



&НаКлиенте
Процедура ОткрытьОтбор(Команда)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ВидНоменклатуры", ВидНоменклатуры);
	
	ОткрытьФорму("Обработка.кт_ПрайсЛистПроизводства.Форма.ФормаОтбораНоменклатуры", ПараметрыОткрытия, ЭтаФорма);	
КонецПроцедуры
&НаКлиенте
Процедура УстановитьОтборИзОкна(НовыйВидНоменклатуры, НовыеПараметрыОтбора) Экспорт
	
	ВидНоменклатуры = НовыйВидНоменклатуры;
	ЗаполнитьПараметрыОтбораИзМассиваНаСервере(НовыеПараметрыОтбора);
	
	Сообщить("Параметров отбора получено: " + Строка(НовыеПараметрыОтбора.Количество()));
	
	СобратьИПостроитьТаблицуНаСервере();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПараметрыОтбораИзМассиваНаСервере(НовыеПараметрыОтбора)
	ТаблицаОтбора = РеквизитФормыВЗначение("ПараметрыОтбора");
	МассивДобавляемых = Новый Массив;
	
	Если ТаблицаОтбора.Колонки.Найти("Свойство") = Неопределено Тогда
		МассивДобавляемых.Добавить(Новый РеквизитФормы("Свойство", Новый ОписаниеТипов("Строка"), "ПараметрыОтбора"));
	КонецЕсли;
	Если ТаблицаОтбора.Колонки.Найти("Значение") = Неопределено Тогда
		МассивДобавляемых.Добавить(Новый РеквизитФормы("Значение", Новый ОписаниеТипов("Строка"), "ПараметрыОтбора"));
	КонецЕсли;
	
	Если МассивДобавляемых.Количество() > 0 Тогда
		ИзменитьРеквизиты(МассивДобавляемых);
	КонецЕсли;
	
	ТаблицаПараметров = Новый ТаблицаЗначений;
	ТаблицаПараметров.Колонки.Добавить("Свойство");
	ТаблицаПараметров.Колонки.Добавить("Значение");
	
	Если НовыеПараметрыОтбора <> Неопределено Тогда
		Для Каждого СтрПарам Из НовыеПараметрыОтбора Цикл
			НоваяСтрока = ТаблицаПараметров.Добавить();
			НоваяСтрока["Свойство"] = СокрЛП(Строка(СтрПарам.Свойство));
			НоваяСтрока["Значение"] = СокрЛП(Строка(СтрПарам.Значение));
		КонецЦикла;
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(ТаблицаПараметров, "ПараметрыОтбора");
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокНоменклатурыПоОтбору()
	Результат = Новый Массив;
	
	Если Не ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТаблицаОтбора = РеквизитФормыВЗначение("ПараметрыОтбора");
	Если ТаблицаОтбора = Неопределено Или ТаблицаОтбора.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если ТаблицаОтбора.Колонки.Найти("Свойство") = Неопределено Или ТаблицаОтбора.Колонки.Найти("Значение") = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ДопРекв.Ссылка КАК Номенклатура,
	|	ДопРекв.Свойство КАК Свойство,
	|	ДопРекв.Значение КАК Значение
	|ИЗ
	|	Справочник.Номенклатура.ДополнительныеРеквизиты КАК ДопРекв
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Номенклатура
	|		ПО ДопРекв.Ссылка = Номенклатура.Ссылка
	|ГДЕ
	|	Номенклатура.ВидНоменклатуры = &ВидНоменклатуры
	|	И Номенклатура.ЭтоГруппа = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
	ДанныеПоНоменклатуре = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		СвойстваНоменклатуры = ДанныеПоНоменклатуре.Получить(Выборка.Номенклатура);
		Если СвойстваНоменклатуры = Неопределено Тогда
			СвойстваНоменклатуры = Новый Соответствие;
			ДанныеПоНоменклатуре.Вставить(Выборка.Номенклатура, СвойстваНоменклатуры);
		КонецЕсли;
		
		СвойстваНоменклатуры.Вставить(СокрЛП(Строка(Выборка.Свойство)), Выборка.Значение);
	КонецЦикла;
	
	Для Каждого ЭлементСоответствия Из ДанныеПоНоменклатуре Цикл
		Подходит = Истина;
		СвойстваНоменклатуры = ЭлементСоответствия.Значение;
		
		Для Каждого СтрОтбора Из ТаблицаОтбора Цикл
			ЗначениеСвойстваВБазе = СвойстваНоменклатуры.Получить(СокрЛП(Строка(СтрОтбора["Свойство"])));
			Если ЗначениеСвойстваВБазе = Неопределено Тогда
				Подходит = Ложь;
				Прервать;
			КонецЕсли;
			
			Если Не ЗначенияОтбораСовпадают(ЗначениеСвойстваВБазе, СтрОтбора["Значение"]) Тогда
				Подходит = Ложь;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если Подходит Тогда
			Результат.Добавить(ЭлементСоответствия.Ключ);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
КонецФункции

&НаСервере
Функция ЗначенияОтбораСовпадают(ЗначениеСвойства, ЗначениеОтбораСтрока)
	СтрокаСвойства = НРег(СокрЛП(Строка(ЗначениеСвойства)));
	СтрокаОтбора = НРег(СокрЛП(Строка(ЗначениеОтбораСтрока)));
	
	Если ЗначениеЗаполнено(СтрокаСвойства) И СтрокаСвойства = СтрокаОтбора Тогда
		Возврат Истина;
	КонецЕсли;
	
	Попытка
		Если Число(ЗначениеСвойства) = Число(ЗначениеОтбораСтрока) Тогда
			Возврат Истина;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	Возврат Ложь;
КонецФункции

