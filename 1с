&НаСервере
Процедура ЗаполнитьДеревоМатериаловИзКонтекстаТИНаСервере(ТаблицаТИ)

	Дерево = СоздатьПустоеДеревоМатериалов();

	Если ТаблицаТИ = Неопределено Тогда
		ЗначениеВРеквизитФормы(Дерево, "ДеревоМатериалов");
		Возврат;
	КонецЕсли;

	Если ТаблицаТИ.Количество() = 0 Тогда
		ЗначениеВРеквизитФормы(Дерево, "ДеревоМатериалов");
		Возврат;
	КонецЕсли;

	// === ДИАГНОСТИКА: что в ТаблицаТИ ===
	СтрДиаг = Дерево.Строки.Добавить();
	СтрДиаг.Материал = "ДИАГ: строк=" + Строка(ТаблицаТИ.Количество()) + " колонок=" + Строка(ТаблицаТИ.Колонки.Количество());

	Для Каждого Кол Из ТаблицаТИ.Колонки Цикл
		СтрК = Дерево.Строки.Добавить();
		СтрК.Материал = "ДИАГ колонка: [" + Кол.Имя + "]";
	КонецЦикла;

	Если ТаблицаТИ.Количество() > 0 Тогда
		ПерваяСтрока = ТаблицаТИ[0];
		Для Каждого Кол Из ТаблицаТИ.Колонки Цикл
			Попытка
				СтрЗ = Дерево.Строки.Добавить();
				СтрЗ.Материал = "ДИАГ [" + Кол.Имя + "]=" + Строка(ПерваяСтрока[Кол.Имя]) + " тип:" + Строка(ТипЗнч(ПерваяСтрока[Кол.Имя]));
			Исключение
				СтрЗ = Дерево.Строки.Добавить();
				СтрЗ.Материал = "ДИАГ [" + Кол.Имя + "] ошибка чтения";
			КонецПопытки;
		КонецЦикла;
	КонецЕсли;
	// === КОНЕЦ ДИАГНОСТИКИ ===

	ОбщееТУ = ПолучитьОбщееТУДляМатериалов(ТаблицаТИ);
	Если Не ЗначениеЗаполнено(ОбщееТУ) Тогда
		СтрокаДиагностики = Дерево.Строки.Добавить();
		СтрокаДиагностики.Материал = "[общее ТУ не найдено]";
		ЗначениеВРеквизитФормы(Дерево, "ДеревоМатериалов");
		Возврат;
	КонецЕсли;

	// ДИАГ: показать найденное ТУ
	СтрДиагТУ = Дерево.Строки.Добавить();
	СтрДиагТУ.Материал = "ДИАГ: найдено ТУ = " + Строка(ОбщееТУ);

	ЭлементыТУМатериалов = ПолучитьМатериальныеЭлементыТУДляМатериалов(ОбщееТУ);

	// ДИАГ: показать найденные элементы ТУ
	СтрДиагЭл = Дерево.Строки.Добавить();
	СтрДиагЭл.Материал = "ДИАГ: элементов ТУ найдено = " + Строка(ЭлементыТУМатериалов.Количество());
	Для Каждого ЭлТУ Из ЭлементыТУМатериалов Цикл
		СтрДиагЭлДет = Дерево.Строки.Добавить();
		СтрДиагЭлДет.Материал = "  ДИАГ элемТУ: " + Строка(ЭлТУ);
	КонецЦикла;

	Если ЭлементыТУМатериалов.Количество() = 0 Тогда
		СтрокаДиагностики = Дерево.Строки.Добавить();
		СтрокаДиагностики.Материал = "[материальные элементы ТУ не найдены]";
		ЗначениеВРеквизитФормы(Дерево, "ДеревоМатериалов");
		Возврат;
	КонецЕсли;

	// ДИАГ: проверим какие табличные части есть у ТИ
	Попытка
		ПерваяТИ = Неопределено;
		Для Каждого СтрТИ Из ТаблицаТИ Цикл
			Если ЗначениеЗаполнено(СтрТИ["ТехнологическаяИнструкция"]) Тогда
				ПерваяТИ = СтрТИ["ТехнологическаяИнструкция"];
				Прервать;
			КонецЕсли;
		КонецЦикла;
		Если ЗначениеЗаполнено(ПерваяТИ) Тогда
			МетаданныеТИ = ПерваяТИ.Метаданные();
			ДиагТЧ = Дерево.Строки.Добавить();
			ДиагТЧ.Материал = "ДИАГ: табличные части ТИ:";
			Для Каждого ТЧ Из МетаданныеТИ.ТабличныеЧасти Цикл
				ДиагТЧДет = Дерево.Строки.Добавить();
				ДиагТЧДет.Материал = "  ДИАГ ТЧ: " + ТЧ.Имя;
				// Показать колонки этой ТЧ
				СписокКолонок = "";
				Для Каждого Рекв Из ТЧ.Реквизиты Цикл
					СписокКолонок = СписокКолонок + Рекв.Имя + ", ";
				КонецЦикла;
				ДиагТЧКол = Дерево.Строки.Добавить();
				ДиагТЧКол.Материал = "    колонки: " + СписокКолонок;
			КонецЦикла;
		КонецЕсли;
	Исключение
		ДиагОшибка = Дерево.Строки.Добавить();
		ДиагОшибка.Материал = "ДИАГ: ошибка метаданных ТИ: " + ОписаниеОшибки();
	КонецПопытки;

	Группа = Дерево.Строки.Добавить();
	Группа.Материал = "Текущие ТИ";

	СчетчикТИ = 0;
	Для Каждого СтрТИ Из ТаблицаТИ Цикл

		Если Не ЗначениеЗаполнено(СтрТИ["ТехнологическаяИнструкция"]) Тогда
			Продолжить;
		КонецЕсли;

		СчетчикТИ = СчетчикТИ + 1;
		Если СчетчикТИ > 3 Тогда
			// Для диагностики достаточно первых 3 ТИ
			УзелОстаток = Группа.Строки.Добавить();
			УзелОстаток.Материал = "... и ещё ТИ (показаны первые 3)";
			Прервать;
		КонецЕсли;

		УзелТИ = Группа.Строки.Добавить();
		УзелТИ.Материал = Строка(СтрТИ["ТехнологическаяИнструкция"]);
		УзелТИ.ЦенаБухУчета = 0;
		УзелТИ.ЦенаОМТО = 0;
		УзелТИ.ЦенаДляРасчета = 0;

		МатериалыТИ = ПолучитьМатериалыИзТИПоЭлементамТУДляМатериалов(
			СтрТИ["ТехнологическаяИнструкция"],
			ЭлементыТУМатериалов
		);

		Если МатериалыТИ.Количество() = 0 Тогда
			ПустаяСтрока = УзелТИ.Строки.Добавить();
			ПустаяСтрока.Материал = "[материалы по элементам ТУ не найдены]";
			ПустаяСтрока.ЦенаБухУчета = 0;
			ПустаяСтрока.ЦенаОМТО = 0;
			ПустаяСтрока.ЦенаДляРасчета = 0;
			Продолжить;
		КонецЕсли;

		Для Каждого Материал Из МатериалыТИ Цикл
			СтрокаМатериала = УзелТИ.Строки.Добавить();
			СтрокаМатериала.Материал = Строка(Материал);
			СтрокаМатериала.ЦенаБухУчета = 0;
			СтрокаМатериала.ЦенаОМТО = 0;
			СтрокаМатериала.ЦенаДляРасчета = 0;
		КонецЦикла;

	КонецЦикла;

	ЗначениеВРеквизитФормы(Дерево, "ДеревоМатериалов");

КонецПроцедуры

