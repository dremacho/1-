&НаСервере
Функция ПолучитьКандидатыМатериаловИзОднойТИ(ТехнологическаяИнструкция)

	Результат = Новый Массив;

	Если Не ЗначениеЗаполнено(ТехнологическаяИнструкция) Тогда
		Возврат Результат;
	КонецЕсли;

	ТУ = ПолучитьТУДляМатериаловПоТИ(ТехнологическаяИнструкция);
	Если Не ЗначениеЗаполнено(ТУ) Тогда
		Возврат Результат;
	КонецЕсли;

	ЭлементыТУМатериалов = ПолучитьМатериальныеЭлементыТУДляМатериалов(ТУ);
	Если ЭлементыТУМатериалов.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	Возврат ПолучитьМатериалыИзТИПоЭлементамТУДляМатериалов(ТехнологическаяИнструкция, ЭлементыТУМатериалов);

КонецФункции

&НаСервере
Функция ПолучитьТУДляМатериаловПоТИ(ТехнологическаяИнструкция)

	Если Не ЗначениеЗаполнено(ТехнологическаяИнструкция) Тогда
		Возврат Неопределено;
	КонецЕсли;

	ВариантыЗапросов = Новый Массив;

	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТИ.ТехнологическоеУсловие КАК ТУ
	|ИЗ
	|	Справочник.кт_ТехнологическиеИнструкции КАК ТИ
	|ГДЕ
	|	ТИ.Ссылка = &ТИ");

	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТИ.ТУ КАК ТУ
	|ИЗ
	|	Справочник.кт_ТехнологическиеИнструкции КАК ТИ
	|ГДЕ
	|	ТИ.Ссылка = &ТИ");

	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТИ.Условия КАК ТУ
	|ИЗ
	|	Справочник.кт_ТехнологическиеИнструкции КАК ТИ
	|ГДЕ
	|	ТИ.Ссылка = &ТИ");

	Счетчик = 0;
	Для Каждого ТекстЗапроса Из ВариантыЗапросов Цикл
		Счетчик = Счетчик + 1;
		Попытка
			Запрос = Новый Запрос;
			Запрос.Текст = ТекстЗапроса;
			Запрос.УстановитьПараметр("ТИ", ТехнологическаяИнструкция);

			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				Сообщить("ПолучитьТУПоТИ вариант " + Счетчик + ": запрос выполнен, ТУ = " + Строка(Выборка.ТУ));
				Если ЗначениеЗаполнено(Выборка.ТУ) Тогда
					Возврат Выборка.ТУ;
				Иначе
					Сообщить("ПолучитьТУПоТИ вариант " + Счетчик + ": ТУ пустое");
				КонецЕсли;
			Иначе
				Сообщить("ПолучитьТУПоТИ вариант " + Счетчик + ": нет строк в результате");
			КонецЕсли;
		Исключение
			Сообщить("ПолучитьТУПоТИ вариант " + Счетчик + " ОШИБКА: " + ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;

	Возврат Неопределено;

КонецФункции

&НаСервере
Функция ПолучитьОбщееТУДляМатериалов(ТаблицаТИ)

	ДиагЛог = Новый Массив; // собираем диагностику

	// Сначала пробуем из таблицы ТИ
	ЕстьНепустаяТИ = Ложь;
	Если ТаблицаТИ <> Неопределено Тогда
		Для Каждого СтрТИ Из ТаблицаТИ Цикл
			Если ЗначениеЗаполнено(СтрТИ["ТехнологическаяИнструкция"]) Тогда
				ЕстьНепустаяТИ = Истина;
				ДиагЛог.Добавить("ТУ_ДИАГ: нашли непустую ТИ=" + Строка(СтрТИ["ТехнологическаяИнструкция"]));
				ТУ = ПолучитьТУДляМатериаловПоТИ(СтрТИ["ТехнологическаяИнструкция"]);
				Если ЗначениеЗаполнено(ТУ) Тогда
					ДиагЛог.Добавить("ТУ_ДИАГ: получили ТУ из ТИ = " + Строка(ТУ));
					Возврат ТУ;
				Иначе
					ДиагЛог.Добавить("ТУ_ДИАГ: ТУ из ТИ пустое");
				КонецЕсли;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Если Не ЕстьНепустаяТИ Тогда
		ДиагЛог.Добавить("ТУ_ДИАГ: все ТИ в таблице пустые, ищем напрямую");
	КонецЕсли;

	Если Не ЗначениеЗаполнено(ВидНоменклатуры) Тогда
		ДиагЛог.Добавить("ТУ_ДИАГ: ВидНоменклатуры пуст!");
		ВывестиДиагТУВДерево(ДиагЛог);
		Возврат Неопределено;
	КонецЕсли;

	ДиагЛог.Добавить("ТУ_ДИАГ: ВидНоменклатуры=" + Строка(ВидНоменклатуры));

	// Сначала проверим — есть ли вообще записи в регистре для этого вида
	Попытка
		ЗапросПроверки = Новый Запрос;
		ЗапросПроверки.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Рег.ТехнологическаяИнструкция КАК ТИ
		|ИЗ
		|	РегистрСведений.кт_АктуальнаяТИНоменклатуры КАК Рег
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
		|		ПО Рег.Номенклатура = Ном.Ссылка
		|ГДЕ
		|	Ном.ВидНоменклатуры = &ВидНоменклатуры";
		ЗапросПроверки.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
		ВыборкаПроверки = ЗапросПроверки.Выполнить().Выбрать();
		Если ВыборкаПроверки.Следующий() Тогда
			ДиагЛог.Добавить("ТУ_ДИАГ: в регистре ЕСТЬ ТИ для этого вида: " + Строка(ВыборкаПроверки.ТИ));
		Иначе
			ДиагЛог.Добавить("ТУ_ДИАГ: в регистре НЕТ записей для этого ВидНоменклатуры");
		КонецЕсли;
	Исключение
		ДиагЛог.Добавить("ТУ_ДИАГ: ошибка проверки регистра: " + ОписаниеОшибки());
	КонецПопытки;

	ВариантыЗапросов = Новый Массив;
	ОписанияВариантов = Новый Массив;

	// Через регистр актуальных ТИ → справочник ТИ → реквизит ТУ
	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТИСпр.ТехнологическоеУсловие КАК ТУ
	|ИЗ
	|	РегистрСведений.кт_АктуальнаяТИНоменклатуры КАК Рег
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО Рег.Номенклатура = Ном.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.кт_ТехнологическиеИнструкции КАК ТИСпр
	|		ПО Рег.ТехнологическаяИнструкция = ТИСпр.Ссылка
	|ГДЕ
	|	Ном.ВидНоменклатуры = &ВидНоменклатуры");
	ОписанияВариантов.Добавить("Рег→ТИСпр.ТехнологическоеУсловие");

	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТИСпр.ТУ КАК ТУ
	|ИЗ
	|	РегистрСведений.кт_АктуальнаяТИНоменклатуры КАК Рег
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО Рег.Номенклатура = Ном.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.кт_ТехнологическиеИнструкции КАК ТИСпр
	|		ПО Рег.ТехнологическаяИнструкция = ТИСпр.Ссылка
	|ГДЕ
	|	Ном.ВидНоменклатуры = &ВидНоменклатуры");
	ОписанияВариантов.Добавить("Рег→ТИСпр.ТУ");

	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТИСпр.Условия КАК ТУ
	|ИЗ
	|	РегистрСведений.кт_АктуальнаяТИНоменклатуры КАК Рег
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Ном
	|		ПО Рег.Номенклатура = Ном.Ссылка
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.кт_ТехнологическиеИнструкции КАК ТИСпр
	|		ПО Рег.ТехнологическаяИнструкция = ТИСпр.Ссылка
	|ГДЕ
	|	Ном.ВидНоменклатуры = &ВидНоменклатуры");
	ОписанияВариантов.Добавить("Рег→ТИСпр.Условия");

	// Запасные варианты: напрямую через справочник ТУ
	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТУ.Ссылка КАК ТУ
	|ИЗ
	|	Справочник.кт_ТехнологическиеУсловия КАК ТУ
	|ГДЕ
	|	ТУ.Продукция.ВидНоменклатуры = &ВидНоменклатуры");
	ОписанияВариантов.Добавить("ТУ.Продукция.ВидНоменклатуры");

	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТУ.Ссылка КАК ТУ
	|ИЗ
	|	Справочник.кт_ТехнологическиеУсловия КАК ТУ
	|ГДЕ
	|	ТУ.ВидПродукции = &ВидНоменклатуры");
	ОписанияВариантов.Добавить("ТУ.ВидПродукции");

	// Ещё вариант — ТУ.Владелец = ВидНоменклатуры (если ТУ подчинен виду)
	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТУ.Ссылка КАК ТУ
	|ИЗ
	|	Справочник.кт_ТехнологическиеУсловия КАК ТУ
	|ГДЕ
	|	ТУ.Владелец = &ВидНоменклатуры");
	ОписанияВариантов.Добавить("ТУ.Владелец=ВидНом");

	// Ещё вариант — просто любое ТУ, у которого наименование содержит вид
	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ТУ.Ссылка КАК ТУ
	|ИЗ
	|	Справочник.кт_ТехнологическиеУсловия КАК ТУ
	|ГДЕ
	|	ТУ.Наименование ПОДОБНО &ИмяВида");
	ОписанияВариантов.Добавить("ТУ.Наименование ПОДОБНО ВидНом");

	Счетчик = 0;
	Для Каждого ТекстЗапроса Из ВариантыЗапросов Цикл
		Счетчик = Счетчик + 1;
		Попытка
			Запрос = Новый Запрос;
			Запрос.Текст = ТекстЗапроса;
			Запрос.УстановитьПараметр("ВидНоменклатуры", ВидНоменклатуры);
			Попытка
				Запрос.УстановитьПараметр("ИмяВида", "%" + Строка(ВидНоменклатуры) + "%");
			Исключение
			КонецПопытки;

			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда
				Если ЗначениеЗаполнено(Выборка.ТУ) Тогда
					ДиагЛог.Добавить("ТУ_ДИАГ: НАЙДЕНО вариант " + Счетчик + " (" + ОписанияВариантов[Счетчик - 1] + "): " + Строка(Выборка.ТУ));
					ВывестиДиагТУВДерево(ДиагЛог);
					Возврат Выборка.ТУ;
				Иначе
					ДиагЛог.Добавить("ТУ_ДИАГ: вариант " + Счетчик + " (" + ОписанияВариантов[Счетчик - 1] + "): строка есть, но ТУ пустое");
				КонецЕсли;
			Иначе
				ДиагЛог.Добавить("ТУ_ДИАГ: вариант " + Счетчик + " (" + ОписанияВариантов[Счетчик - 1] + "): нет строк");
			КонецЕсли;
		Исключение
			ДиагЛог.Добавить("ТУ_ДИАГ: вариант " + Счетчик + " (" + ОписанияВариантов[Счетчик - 1] + ") ОШИБКА: " + ОписаниеОшибки());
		КонецПопытки;
	КонецЦикла;

	ДиагЛог.Добавить("ТУ_ДИАГ: все варианты исчерпаны, ТУ не найдено");
	ВывестиДиагТУВДерево(ДиагЛог);
	Возврат Неопределено;

КонецФункции

&НаСервере
Процедура ВывестиДиагТУВДерево(ДиагЛог)
	// Выводим диагностику прямо в дерево материалов — Сообщить не видно
	Попытка
		Дерево = РеквизитФормыВЗначение("ДеревоМатериалов");
		Для Каждого Стр Из ДиагЛог Цикл
			НоваяСтрока = Дерево.Строки.Добавить();
			НоваяСтрока.Материал = Стр;
		КонецЦикла;
		ЗначениеВРеквизитФормы(Дерево, "ДеревоМатериалов");
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервере
Функция ПолучитьМатериальныеЭлементыТУДляМатериалов(ТУ)

	Результат = Новый Массив;

	Если Не ЗначениеЗаполнено(ТУ) Тогда
		Возврат Результат;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	кт_ТехнологическиеУсловияОсновныеРезультатыОпераций.ТМЦ КАК ТМЦ,
	|	ИСТИНА КАК ЭтоПолуфабрикат
	|ПОМЕСТИТЬ втТМЦ
	|ИЗ
	|	Справочник.кт_ТехнологическиеУсловия.ОсновныеРезультатыОпераций КАК кт_ТехнологическиеУсловияОсновныеРезультатыОпераций
	|ГДЕ
	|	кт_ТехнологическиеУсловияОсновныеРезультатыОпераций.Ссылка = &ТУ
	|	И кт_ТехнологическиеУсловияОсновныеРезультатыОпераций.ТМЦ ССЫЛКА Справочник.кт_ЭлементыТУ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	кт_ТехнологическиеУсловияСырье.ТМЦ,
	|	НЕ ОсновныеРезультаты.ТМЦ ЕСТЬ NULL
	|ИЗ
	|	Справочник.кт_ТехнологическиеУсловия.Сырье КАК кт_ТехнологическиеУсловияСырье
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.кт_ТехнологическиеУсловия.ОсновныеРезультатыОпераций КАК ОсновныеРезультаты
	|		ПО (ОсновныеРезультаты.Ссылка = кт_ТехнологическиеУсловияСырье.Ссылка)
	|			И (ОсновныеРезультаты.ТМЦ = кт_ТехнологическиеУсловияСырье.ТМЦ)
	|ГДЕ
	|	кт_ТехнологическиеУсловияСырье.Ссылка = &ТУ
	|	И кт_ТехнологическиеУсловияСырье.ТМЦ ССЫЛКА Справочник.кт_ЭлементыТУ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(втТМЦ.ЭтоПолуфабрикат) КАК ЭтоПолуфабрикат,
	|	втТМЦ.ТМЦ КАК ЭлементТУ
	|ПОМЕСТИТЬ втЭлементыТУ
	|ИЗ
	|	втТМЦ КАК втТМЦ
	|СГРУППИРОВАТЬ ПО
	|	втТМЦ.ТМЦ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	втЭлементыТУ.ЭлементТУ КАК ЭлементТУ
	|ИЗ
	|	втЭлементыТУ КАК втЭлементыТУ
	|ГДЕ
	|	НЕ втЭлементыТУ.ЭтоПолуфабрикат";

	Запрос.УстановитьПараметр("ТУ", ТУ);

	МассивРезультатов = Запрос.ВыполнитьПакет();
	Если МассивРезультатов.Количество() < 3 Тогда
		Возврат Результат;
	КонецЕсли;

	Выборка = МассивРезультатов[2].Выбрать();
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.ЭлементТУ) Тогда
			Результат.Добавить(Выборка.ЭлементТУ);
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

&НаСервере
Функция ПолучитьМатериалыИзТИПоЭлементамТУДляМатериалов(ТехнологическаяИнструкция, ЭлементыТУМатериалов)

	Результат = Новый Массив;

	Если Не ЗначениеЗаполнено(ТехнологическаяИнструкция) Тогда
		Возврат Результат;
	КонецЕсли;

	Если ЭлементыТУМатериалов = Неопределено Или ЭлементыТУМатериалов.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	ВариантыЗапросов = Новый Массив;

	// Основной вариант: ТЧ "ЭлементыТУ", колонки "ЭлементТУ" и "Значение"
	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЭлементыТУТИ.Значение КАК Материал
	|ИЗ
	|	Справочник.кт_ТехнологическиеИнструкции.ЭлементыТУ КАК ЭлементыТУТИ
	|ГДЕ
	|	ЭлементыТУТИ.Ссылка = &ТИ
	|	И ЭлементыТУТИ.ЭлементТУ В (&ЭлементыТУ)
	|	И ЭлементыТУТИ.Значение ССЫЛКА Справочник.Номенклатура");

	// Без фильтра по ЭлементТУ — вдруг все значения нужны
	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЭлементыТУТИ.Значение КАК Материал
	|ИЗ
	|	Справочник.кт_ТехнологическиеИнструкции.ЭлементыТУ КАК ЭлементыТУТИ
	|ГДЕ
	|	ЭлементыТУТИ.Ссылка = &ТИ
	|	И ЭлементыТУТИ.Значение ССЫЛКА Справочник.Номенклатура");

	// Через ПараметрыТУ — тоже есть такая ТЧ с колонкой Значение
	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПарамТУ.Значение КАК Материал
	|ИЗ
	|	Справочник.кт_ТехнологическиеИнструкции.ПараметрыТУ КАК ПарамТУ
	|ГДЕ
	|	ПарамТУ.Ссылка = &ТИ
	|	И ПарамТУ.Значение ССЫЛКА Справочник.Номенклатура");

	// Через СырьеРазделовОперационныхЛистов — ТМЦ
	ВариантыЗапросов.Добавить(
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Сырье.ТМЦ КАК Материал
	|ИЗ
	|	Справочник.кт_ТехнологическиеИнструкции.СырьеРазделовОперационныхЛистов КАК Сырье
	|ГДЕ
	|	Сырье.Ссылка = &ТИ
	|	И Сырье.ТМЦ ССЫЛКА Справочник.Номенклатура");

	ДиагМат = Новый Массив;
	ОписанияВариантов = Новый Массив;
	ОписанияВариантов.Добавить("ЭлементыТУ.Значение по ЭлементТУ");
	ОписанияВариантов.Добавить("ЭлементыТУ.Значение (все)");
	ОписанияВариантов.Добавить("ПараметрыТУ.Значение");
	ОписанияВариантов.Добавить("СырьеРазделовОЛ.ТМЦ");

	Счетчик = 0;
	Для Каждого ТекстЗапроса Из ВариантыЗапросов Цикл
		Счетчик = Счетчик + 1;
		Описание = ОписанияВариантов[Счетчик - 1];

		Попытка
			Запрос = Новый Запрос;
			Запрос.Текст = ТекстЗапроса;
			Запрос.УстановитьПараметр("ТИ", ТехнологическаяИнструкция);
			Запрос.УстановитьПараметр("ЭлементыТУ", ЭлементыТУМатериалов);

			Выборка = Запрос.Выполнить().Выбрать();
			КолвоСтрок = 0;
			Пока Выборка.Следующий() Цикл
				КолвоСтрок = КолвоСтрок + 1;
				Если ЗначениеЗаполнено(Выборка.Материал) Тогда
					Результат.Добавить(Выборка.Материал);
				КонецЕсли;
			КонецЦикла;

			ДиагМат.Добавить("МАТ_ДИАГ вар " + Счетчик + " (" + Описание + "): строк=" + КолвоСтрок + " найдено=" + Результат.Количество());

			Если Результат.Количество() > 0 Тогда
				ВывестиДиагМатВДерево(ДиагМат);
				Возврат УдалитьДублиМатериалов(Результат);
			КонецЕсли;

		Исключение
			ДиагМат.Добавить("МАТ_ДИАГ вар " + Счетчик + " (" + Описание + ") ОШИБКА: " + ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	ДиагМат.Добавить("МАТ_ДИАГ: все варианты не дали результата для ТИ=" + Строка(ТехнологическаяИнструкция));
	ВывестиДиагМатВДерево(ДиагМат);
	Возврат УдалитьДублиМатериалов(Результат);

КонецФункции

&НаСервере
Процедура ВывестиДиагМатВДерево(ДиагМат)
	Попытка
		Дерево = РеквизитФормыВЗначение("ДеревоМатериалов");
		Для Каждого Стр Из ДиагМат Цикл
			НоваяСтрока = Дерево.Строки.Добавить();
			НоваяСтрока.Материал = Стр;
		КонецЦикла;
		ЗначениеВРеквизитФормы(Дерево, "ДеревоМатериалов");
	Исключение
	КонецПопытки;
КонецПроцедуры

&НаСервере
Функция УдалитьДублиМатериалов(МассивМатериалов)

	Результат = Новый Массив;
	Уникальные = Новый Соответствие;

	Если МассивМатериалов = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого Материал Из МассивМатериалов Цикл
		Если Не ЗначениеЗаполнено(Материал) Тогда
			Продолжить;
		КонецЕсли;

		Если Уникальные.Получить(Материал) = Неопределено Тогда
			Уникальные.Вставить(Материал, Истина);
			Результат.Добавить(Материал);
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;

КонецФункции

